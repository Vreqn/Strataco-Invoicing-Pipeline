# Strataco Invoice Automation — environment configuration
# Copy this file to .env and fill in the real values.
# .env is gitignored and must never be committed.

# Root of the Strataco files tree on this machine.
# On the deployment machine, point this at whatever Windows path the n8n
# Docker volume is bind-mounted to (the same files the N8n flow uses).
STRATACO_ROOT=D:\Strataco

# Microsoft Graph (Azure AD) — application credentials for the test/prod mailbox.
# Required scopes on the app registration: Mail.Read, Mail.ReadWrite, Mail.Send,
# MailboxSettings.Read.
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# UPN of the mailbox the intake step polls.
MAILBOX_UPN=testinvsml@stratacomgmt.com

# During the shadow/test phase, all manager and AP notification emails are
# rerouted here. Set to empty string to send to the real recipients.
NOTIFY_OVERRIDE_EMAIL=attila@ati-netwks.ca

# Default recipient for system-wide summary emails (e.g. Step 6's processed
# and unmatched summaries). Used as the fallback when NOTIFY_OVERRIDE_EMAIL
# is empty (post-cutover). Required — the code refuses to send to a hardcoded
# address.
NOTIFY_DEFAULT_EMAIL=attila@ati-netwks.ca

# Optional: override the default <STRATACO_ROOT>/logs location.
# LOG_DIR=

# Optional: override Graph retry behaviour.
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY_SECONDS=2

# Optional: Step 2 zip-bomb guards (defaults shown).
# ZIP_MAX_ENTRIES=200
# ZIP_MAX_UNCOMPRESSED_BYTES=104857600   # 100 MB per entry
# ZIP_MAX_TOTAL_BYTES=524288000          # 500 MB total uncompressed per zip
# ZIP_MAX_RATIO=100                      # uncompressed:compressed ratio cap

# Secrets — never commit
.env
credentials.json
token.json
*.pem
*.key
*.pfx
*.p12

# Python build artifacts
__pycache__/
*.pyc
*.pyo

# Runtime state — generated by Steps, not source
_state/
logs/*.log
logs/*.lock
logs/*.csv
*.tmp.*

# Local working directories
.tmp/
reference/
codex-router-out/

# IDE / editor metadata
.vscode/
.idea/
*.swp

# OS metadata
.DS_Store
Thumbs.db
desktop.ini
